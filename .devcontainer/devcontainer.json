{
  "name": "mvsmf-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd"
      ]
    }
  },
  "postCreateCommand": [
    "npm install -g @zowe/cli",
    "test -f .env || cp .env.example .env",
    "make compiledb"
  ]
}